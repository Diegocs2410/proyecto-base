# ─── Supabase ────────────────────────────────────────────────
# Toma estos valores en supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ─── App ─────────────────────────────────────────────────────
# URL base donde corre la app (sin slash final).
# Dev: http://localhost:3000 · Prod: https://tu-dominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email · Resend (Fase 1) ────────────────────────────────
# Crea una API key en resend.com → API Keys
# Si la dejas vacía, los emails se loggean en consola pero no se envían (modo dry-run).
RESEND_API_KEY=
# Remitente verificado. En dev puedes usar "Proyecto Base <onboarding@resend.dev>"
# (solo envía al dueño de la API key). En prod usa tu dominio verificado.
EMAIL_FROM="Proyecto Base <soporte@diegocarreno.online>"

# ─── Pagos · Wompi (Fase 2) ─────────────────────────────────
# https://docs.wompi.co · Usa sandbox primero.
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=

# ─── Observabilidad (Fase 5) ────────────────────────────────
# Sentry — error tracking server + client (https://sentry.io).
# Si se dejan vacíos, la app funciona normal pero no reporta errores.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Sólo necesarios en CI/Vercel para subir source maps en build:
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog — analytics de producto (https://posthog.com).
# Vacío = no analytics en este entorno.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Logging — controla el nivel del logger pino (debug/info/warn/error).
LOG_LEVEL=info

# ─── Seeds (opcional, solo dev) ─────────────────────────────
# Si SEED_DEMO_TENANTS=true, npm run seed crea 2 tenants demo.
SEED_DEMO_TENANTS=false
